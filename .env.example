# ═══════════════════════════════════════════════════════════════════
# CHEF IA STUDIO — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════════
#
# INSTRUÇÕES:
# 1. Copie este arquivo: cp .env.example .env
# 2. Preench os valores com suas chaves reais
# 3. NUNCA commite .env para git (já está em .gitignore)
# 4. Variáveis comentadas (#) são opcionais/futuras
#
# ═══════════════════════════════════════════════════════════════════

# SERVIDOR
PORT=3000

# ─────────────────────────────────────────────────────────────────
# PROVIDERS DE IA (OBRIGATÓRIO: escolha um)
# ─────────────────────────────────────────────────────────────────

# Google Gemini (RECOMENDADO AGORA)
# Obtenha em: https://ai.google.dev/
GEMINI_API_KEY=sua_chave_gemini_aqui
GEMINI_MODEL=gemini-flash-lite-latest

# Google Generative AI (LEGADO - será descontinuado)
# Compatibilidade com versão antiga
GOOGLE_API_KEY=sua_chave_google_aqui

# Seleção de provider principal
AI_PROVIDER=gemini

# ─────────────────────────────────────────────────────────────────
# PROVIDERS ALTERNATIVOS (OPCIONAIS - para futuro)
# ─────────────────────────────────────────────────────────────────

# OpenAI
# OPENAI_API_KEY=sua_chave_openai_aqui

# OpenRouter (Gateway Multi-modelo)
# OPENROUTER_API_KEY=sua_chave_openrouter_aqui

# ─────────────────────────────────────────────────────────────────
# IMAGENS (OPCIONAIS - para futuro)
# ─────────────────────────────────────────────────────────────────

# Unsplash (Imagens editoriais)
# UNSPLASH_ACCESS_KEY=sua_chave_unsplash_aqui

# Pexels (Imagens livres)
# PEXELS_API_KEY=sua_chave_pexels_aqui

# ─────────────────────────────────────────────────────────────────
# E-MAIL (OPCIONAIS - para futuro)
# ─────────────────────────────────────────────────────────────────

# EmailJS (para enviar relatórios)
# EMAILJS_PUBLIC_KEY=sua_chave_publica_aqui
# EMAILJS_SERVICE_ID=seu_service_id_aqui
# EMAILJS_TEMPLATE_ID=seu_template_id_aqui

# ─────────────────────────────────────────────────────────────────
# BANCO DE DADOS (OPCIONAIS - para futuro)
# ─────────────────────────────────────────────────────────────────

# Firebase
# FIREBASE_API_KEY=sua_chave_aqui
# FIREBASE_AUTH_DOMAIN=seu_dominio_aqui
# FIREBASE_PROJECT_ID=seu_projeto_aqui
# FIREBASE_STORAGE_BUCKET=seu_bucket_aqui
# FIREBASE_MESSAGING_SENDER_ID=seu_id_aqui
# FIREBASE_APP_ID=seu_app_id_aqui

# Supabase
# SUPABASE_URL=sua_url_aqui
# SUPABASE_PUBLISHABLE_KEY=sua_chave_publica_aqui
# SUPABASE_SECRET_KEY=sua_chave_secreta_aqui

# ═══════════════════════════════════════════════════════════════════
# FIM DO ARQUIVO .env.example
# ═══════════════════════════════════════════════════════════════════
#
# COMO OBTER AS CHAVES:
#
# 1. GEMINI_API_KEY
#    → Acesse: https://ai.google.dev/
#    → Clique "Get API Key"
#    → Copie a chave
#
# 2. OPENAI_API_KEY (opcional)
#    → Acesse: https://platform.openai.com/
#    → API Keys → Create new secret key
#    → Copie a chave
#
# 3. PEXELS_API_KEY (opcional)
#    → Acesse: https://www.pexels.com/api/
#    → Clique "Request API Access"
#    → Copie a chave
#
# ═══════════════════════════════════════════════════════════════════
