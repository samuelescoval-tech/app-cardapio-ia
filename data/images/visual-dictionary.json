{
  "version": "1.0.0",
  "max_images_per_event": 20,
  "allowed_licenses": ["cc0", "pdm", "by"],
  "default_context": {
    "id": "evento-geral",
    "match": [],
    "query": "event catering",
    "queries": {
      "capa": "event reception",
      "principal": "catering food",
      "sobremesa": "dessert table",
      "bebida": "event drinks",
      "ambiente": "event decoration"
    }
  },
